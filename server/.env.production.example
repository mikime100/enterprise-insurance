PORT=5000
NODE_ENV=production

# Get this from MongoDB Atlas → Connect → Drivers → copy the srv string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/enterprise_insurance?retryWrites=true&w=majority

# Make this a long random string (32+ chars) — used to sign session cookies
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Make this a long random string — used to sign mobile JWT tokens
JWT_SECRET=change-this-to-another-long-random-string

# Your Vercel frontend URL (no trailing slash) — set AFTER you deploy to Vercel
CLIENT_URL=https://your-app.vercel.app
